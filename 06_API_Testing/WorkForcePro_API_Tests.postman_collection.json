      "key": "baseUrl",
      "value": "https://staging.workforcepro.example",
      "type": "string"
    },
    {
      "key": "adminToken",
      "value": "<set-admin-jwt>",
      "type": "string"
    },
    {
      "key": "supervisorToken",
      "value": "<set-supervisor-jwt>",
      "type": "string"
    },
    {
      "key": "employeeToken",
      "value": "<set-employee-jwt>",
      "type": "string"
    },
    {
      "key": "existingEmail",
      "value": "ravi.sharma@workforcepro.com",
      "type": "string"
    },
    {
      "key": "createdEmployeeId",
      "value": "",
      "type": "string"
    },
    {
      "key": "assignmentId",
      "value": "",
      "type": "string"
    },
    {
      "key": "assignedOnlyAssignmentId",
      "value": "9100",
